# ── JWT ───────────────────────────────────────────────────────────────────────
# Минимум 32 символа, случайная строка (openssl rand -base64 48)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# ── База данных ───────────────────────────────────────────────────────────────
# SQLite (по умолчанию для разработки):
# DB_CONNECTION_STRING=Data Source=bimback.db

# PostgreSQL (для продакшна):
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=bimdb;Username=bim;Password=bim_password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Через запятую, без пробелов
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.ru

# ── PostgreSQL (для docker-compose) ───────────────────────────────────────────
POSTGRES_DB=bimdb
POSTGRES_USER=bim
POSTGRES_PASSWORD=bim_password
